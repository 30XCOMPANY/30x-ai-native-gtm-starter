# 30x-ai-native-gtm-starter · sync layer credentials
# Copy this file to `.env` and fill in. NEVER commit `.env` to git.

# === Required ===

# GitHub — for stars velocity, repo signals
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === CRM (pick one) ===

# Attio
ATTIO_API_KEY=
# HubSpot
HUBSPOT_TOKEN=
# Salesforce
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=

# === Notification ===

# Slack — for drift audit + signal alerts
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxxxxxxxxxx
SLACK_CHANNEL_ID=

# === Optional ===

# OpenRouter — usage rankings (scrape, no key needed; only for paid API access)
OPENROUTER_API_KEY=

# Anthropic — used as judge / scoring in skills
ANTHROPIC_API_KEY=

# OpenAI — used as judge / scoring in skills (optional)
OPENAI_API_KEY=

# Reddit OAuth
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT="30x-ai-native-gtm-starter/1.0 by yourusername"

# Product Hunt
PRODUCT_HUNT_DEVELOPER_TOKEN=

# X / Twitter (Basic tier $100/mo)
X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=

# HuggingFace (only needed for private repo access)
HF_TOKEN=

# === Internal ===

# Your own product's API key (if shipping a custom MCP server)
YOUR_PRODUCT_API_KEY=

# Cache location (default: ./cache)
SYNC_CACHE_DIR=./cache

# Notification destinations (comma-separated channels)
ALERT_CHANNELS=slack,email
ALERT_EMAIL=
